# Environment variables for the admin system.
# Local dev: copy to ".env.local". Production: set these in Vercel → Project → Environment Variables.

# Supabase project URL + PUBLIC (publishable) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxx

# SECRET — service-role key for admin operations (create users) and the public
# share PDF routes. SERVER ONLY. Never prefix with NEXT_PUBLIC, never commit.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key...
